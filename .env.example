# Environment Variables Template
# Copy this to .env and fill in your values

# Server Configuration
PORT=8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=innogen
DB_PASSWORD=your-db-password
DB_NAME=innogendb

# JWT Secrets (CRITICAL: Use strong, random secrets)
# Access token secret (for short-lived tokens)
JWT_SECRET=your-very-strong-and-random-access-token-secret-at-least-32-chars

# Refresh token secret (MUST be different from access token secret)
JWT_REFRESH_SECRET=your-very-strong-and-random-refresh-token-secret-at-least-32-chars

# Redis Configuration (for job queue)
REDIS_URL=redis://localhost:6379

# Email Configuration (optional - for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Judge Configuration (optional - for code execution)
# These are used by the piston service for code execution
PISTON_API_URL=https://emkc.org/api/v2/piston

# Security Notes:
# 1. Never commit .env files to version control
# 2. Use strong, randomly generated secrets (32+ characters)
# 3. Access and refresh secrets must be different
# 4. Consider using a secrets manager in production
# 5. Rotate secrets periodically

# Example of generating secure secrets:
# Linux/Mac: openssl rand -base64 32
# Online: https://randomkeygen.com/