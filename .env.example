# Environment Variables Template
# Copy this to .env and fill in your values

# Server Configuration
PORT=8080
MODE=production

# Database Configuration (Docker Compose)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=innogen
POSTGRES_PASSWORD=maiphuongdangyeu
POSTGRES_DB=innogendb

# JWT Secrets (CRITICAL: Use strong, random secrets)
# Access token secret (for short-lived tokens)
JWT_SECRET=your-very-strong-and-random-access-token-secret-at-least-32-chars

# Refresh token secret (MUST be different from access token secret)
JWT_REFRESH_SECRET=your-very-strong-and-random-refresh-token-secret-at-least-32-chars

# Admin password for initial seeding
ADMIN_PASSWORD=admin123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Piston Configuration (for code execution)
PISTON_URL=https://excode.innogenlab.com

# Development Notes:
# - For Docker Compose, database/redis are in docker network
# - For local development without Docker, set:
#   POSTGRES_HOST=localhost
#   REDIS_HOST=localhost
#   (and change ports if needed)

# Security Notes:
# 1. Never commit .env files to version control
# 2. Use strong, randomly generated secrets (32+ characters)
# 3. Access and refresh secrets must be different
# 4. Consider using a secrets manager in production
# 5. Rotate secrets periodically

# Example of generating secure secrets:
# Linux/Mac: openssl rand -base64 32
# Online: https://randomkeygen.com/
